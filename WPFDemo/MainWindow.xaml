<Window x:Class="WPFDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFDemo"
        mc:Ignorable="d"
        Title="Cyberbot Chat" Height="600" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="1" Width="100" Height="80" Margin="0,0,10,0">
                <Image Source="/Logo/chatbot_logo.png" Stretch="Uniform" Margin="5"/>
            </Border>

            <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1" Height="80">
                <TextBlock Text="CYBERBOT CHAT" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
            </Border>
        </Grid>

        <!-- Response Area -->
        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" Margin="0,0,0,10">
            <ScrollViewer Name="scrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel Name="chatPanel" Margin="10">
                    <TextBlock Text="Welcome! Ask me anything about phishing or passwords." 
                               FontSize="14" 
                               Foreground="Gray" 
                               Margin="5" 
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Input Section -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="1" Margin="0,0,10,0">
                <TextBox Name="txtName" BorderThickness="0" VerticalAlignment="Center" Padding="10" FontSize="14" Height="60" KeyDown="TxtName_KeyDown"/>
            </Border>

            <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1" Width="100">
                <Button Content="Submit" BorderThickness="0" Height="60" Click="Button_Click" FontSize="14"/>
            </Border>
        </Grid>
    </Grid>
</Window>
